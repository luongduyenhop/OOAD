@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - Smart Scheduler</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f1f3f4; height: 100vh; display: flex; align-items: center; justify-content: center; }
        .register-card { width: 100%; max-width: 450px; padding: 40px; border: 1px solid #dadce0; border-radius: 8px; background: white; }
        .logo { margin-bottom: 24px; text-align: center; }
        .btn-google { background-color: #1a73e8; color: white; border: none; font-weight: 500; padding: 10px; width: 100%; border-radius: 4px; }
        .form-control { border: 1px solid #dadce0; padding: 10px; border-radius: 4px; }
        .error-msg { color: #d93025; font-size: 0.85rem; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="register-card shadow-sm">
        <div class="logo">
            <img src="https://www.gstatic.com/images/branding/product/1x/calendar_2020q4_48dp.png" width="48" height="48" alt="Logo">
            <h4 class="mt-3 fw-normal">Tạo tài khoản</h4>
            <p class="text-muted">Tham gia cùng Smart Scheduler</p>
        </div>

        <form asp-action="Register" method="post">
            <div class="mb-3">
                <input type="text" name="username" class="form-control" placeholder="Tên người dùng" required autofocus>
            </div>
            <div class="mb-3">
                <input type="password" name="password" class="form-control" placeholder="Mật khẩu" required>
            </div>
            
            @if (ViewBag.Error != null)
            {
                <div class="error-msg mb-3 text-center">@ViewBag.Error</div>
            }

            <button type="submit" class="btn btn-google mt-2">Đăng ký</button>
        </form>

        <div class="mt-4 text-center small">
            <a href="/Account/Login" class="text-decoration-none">Đã có tài khoản? Đăng nhập</a>
        </div>
    </div>
</body>
</html>
